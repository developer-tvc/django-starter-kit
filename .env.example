ENVIRONMENT = develop
ENV = develop

SECRET_KEY = your secret key

PSQL_DB=your db name
PSQL_USER=postgres user
PSQL_PASSWORD=password
# PSQL_HOST=host.docker.internal
PSQL_HOST=localhost
PSQL_PORT=5432

DEBUG=True

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_HOST =smtp.gmail.com
EMAIL_PORT = 587
EMAIL_USE_TLS = True

EMAIL_HOST_USER =your host
EMAIL_HOST_PASSWORD =password

EMAIL_VERIFICATION_ENABLED=True

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_ENABLED=True
LOGIN_LOCK_MINUTES=1


EMAIL_ENABLED=True
SMS_ENABLED=True
IN_APP_ENABLED=True
WEBHOOK_ENABLED=True

CORS_ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
CSRF_TRUSTED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]


SECURE_HSTS_SECONDS=31536000  # 1 year
